# SVACS Dashboard environment configuration
# Copy this file to .env.local and fill in real backend endpoints when integrating.

# When true, the dashboard runs against the in-memory mock adapter (development only).
# Set to "false" in final integration per spec — real APIs only.
VITE_USE_MOCK=true

# Producer endpoints (Phase 6 integration)
VITE_SIGNAL_API=http://localhost:8001
VITE_PERCEPTION_API=http://localhost:8002
VITE_INTELLIGENCE_API=http://localhost:8003
VITE_STATE_API=http://localhost:8004
VITE_BUCKET_API=http://localhost:8005
VITE_TELEMETRY_WS=ws://localhost:8006/telemetry

# Polling fallback (ms) when websocket telemetry is unavailable
VITE_POLL_INTERVAL_MS=2000
